---
interface Props {
  title: string;
  order: number;
}

const { title, order } = Astro.props;
const anchor = `story-${String(order).padStart(2, "0")}`;
---

<article
  id={anchor}
  class="max-w-3xl mx-auto px-6 py-24 prose-styles"
>
  <h3 class="text-3xl md:text-4xl tracking-tight font-semibold mb-6">
    {title}
  </h3>
  <div
    class="text-lg leading-(--leading-relaxed) text-(--color-ink) space-y-6"
  >
    <slot />
  </div>
</article>
