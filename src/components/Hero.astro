---
import { CHROME_COPY } from "../lib/copy";
import Photo from "./Photo.astro";

interface Props {
  anchorPhotoId: string;
}

const { anchorPhotoId } = Astro.props;
const { wordmark, descriptor, tagline } = CHROME_COPY.brand;
---

<header id="top" class="relative min-h-screen flex flex-col">
  <div class="absolute inset-0 -z-10">
    <Photo
      id={anchorPhotoId}
      variant="hero"
      alt={`${wordmark} — anchor image`}
      loading="eager"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-(--color-ink)/30"></div>
  </div>
  <div
    class="flex-1 flex flex-col items-center justify-center text-center px-6 text-(--color-paper) gap-4"
  >
    <p class="uppercase text-xs tracking-[0.3em] opacity-80">{descriptor}</p>
    <h1 class="text-7xl md:text-9xl tracking-tight font-semibold">
      {wordmark}
    </h1>
    <p class="max-w-2xl text-base md:text-lg opacity-90">{tagline}</p>
  </div>
</header>
