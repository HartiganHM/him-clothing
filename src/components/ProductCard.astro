---
import Photo from "./Photo.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  product: CollectionEntry<"products">;
  variant?: "hero" | "compact";
}

const { product, variant = "compact" } = Astro.props;
const { name, category, year, materials, photos } = product.data;
const firstPhoto = photos[0];
if (!firstPhoto) {
  throw new Error(`Product ${product.id} has no photos.`);
}

const href = `/products/${product.data.slug}`;
---
{variant === "hero" ? (
  <a href={href} class="no-underline block group">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      <Photo
        id={firstPhoto}
        variant="hero"
        alt={name}
        class="w-full aspect-[4/5] object-cover"
      />
      <div class="flex flex-col justify-center gap-3">
        <h4 class="text-5xl md:text-6xl tracking-tight font-semibold leading-(--leading-tight)">
          {name}
        </h4>
        <p class="text-(--color-muted)">
          {category} · {year}
        </p>
        {materials.length > 0 && (
          <p class="text-(--color-muted)">{materials.join(" · ")}</p>
        )}
      </div>
    </div>
  </a>
) : (
  <a href={href} class="no-underline block group">
    <div class="flex flex-col gap-2">
      <Photo
        id={firstPhoto}
        variant="card"
        alt={name}
        class="w-full aspect-[4/5] object-cover"
      />
      <p class="text-base font-medium">{name}</p>
      <p class="text-sm text-(--color-muted)">{category} · {year}</p>
    </div>
  </a>
)}
