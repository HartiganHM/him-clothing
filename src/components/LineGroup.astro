---
import ProductCard from "./ProductCard.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  line: string;
  products: CollectionEntry<"products">[];
}

const { line, products } = Astro.props;
const heroes = products.filter((p) => p.data.hero);
const compact = products.filter((p) => !p.data.hero);
---
<section class="max-w-6xl mx-auto px-6 mb-32">
  <header class="mb-12">
    <h3 class="text-3xl tracking-tight mb-2">{line}</h3>
    <p class="text-sm text-(--color-muted)">{products.length} pieces</p>
  </header>

  {heroes.map((product) => (
    <ProductCard product={product} variant="hero" />
  ))}

  {compact.length > 0 && (
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-8">
      {compact.map((product) => (
        <ProductCard product={product} variant="compact" />
      ))}
    </div>
  )}
</section>
